# =============================================================================
# GeoScore backend — copy to `.env` and adjust (see repo README).
# =============================================================================

# --- Database (required when USE_MOCK_WORKFLOW=false) -----------------------
# Matches docker-compose.yml: docker compose up -d
DATABASE_URL=postgresql://geoscore:geoscore@localhost:5432/geoscore

# --- HTTP / CORS -------------------------------------------------------------
# Comma-separated browser origins allowed to call the API (credentials + JSON).
# Local: Next.js default port. Production: add https://your-app.vercel.app (and custom domain).
CORS_ORIGINS=http://localhost:3000

# development | production — production refuses the placeholder JWT secret below.
ENVIRONMENT=development

# --- Scan persistence ---------------------------------------------------------
# false (default): Postgres + real pipeline (DATABASE_URL + Alembic upgrade on API boot; see docs/03-build/database-migrations.md).
# true: in-memory mock workflow — no DB writes, useful for UI-only / CI without Postgres.
USE_MOCK_WORKFLOW=false

# true (default): run ``alembic upgrade head`` during API startup (blocks /health until done).
# false: skip — use when migrations run in a platform pre-deploy / release phase (e.g. Railway) to avoid duplicate work.
RUN_ALEMBIC_ON_STARTUP=true

# --- Auth (MVP JWT) -----------------------------------------------------------
# HS256 signing secret. In production set a long random value (openssl rand -hex 32).
JWT_SECRET_KEY=geoscore-dev-jwt-secret-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_DAYS=30

# --- Playwright (optional render fallback) ------------------------------------
# Requires: pip install -r requirements.txt && playwright install chromium
# Set false on minimal hosts (scan still runs; JS-heavy pages may stay on HTTP capture).
PLAYWRIGHT_ENABLED=true
PLAYWRIGHT_TIMEOUT_MS=25000
PLAYWRIGHT_SETTLE_MS=1200
# PLAYWRIGHT_BROWSERS_PATH=

# --- Optional (not read by app unless you wire them) --------------------------
# LLM_API_KEY=
