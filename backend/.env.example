# Database (use docker-compose postgres or your own)
DATABASE_URL=postgresql://geoscore:geoscore@localhost:5432/geoscore

# API
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:3000

# App
ENVIRONMENT=development
# Set true to use in-memory mock workflow (no Postgres pipeline)
USE_MOCK_WORKFLOW=false

# Optional headless fallback (after HTTP). Disable on hosts without Chromium.
PLAYWRIGHT_ENABLED=true
PLAYWRIGHT_TIMEOUT_MS=25000
PLAYWRIGHT_SETTLE_MS=1200
# After pip install playwright: run `playwright install chromium`
# PLAYWRIGHT_BROWSERS_PATH=

# LLM_API_KEY=
