# =============================================================================
# GeoScore frontend — copy to `.env.local` for local dev (Next.js loads it).
# =============================================================================

# Public: exposed to the browser. Must be the full API origin (no trailing slash).
# Local: same machine as uvicorn. Deployed: your FastAPI/Railway URL, e.g. https://api.example.com
NEXT_PUBLIC_API_URL=http://localhost:8000

# Production checklist:
# - Set NEXT_PUBLIC_API_URL to the deployed API origin.
# - Ensure backend CORS_ORIGINS includes this frontend origin (e.g. https://app.vercel.app).
